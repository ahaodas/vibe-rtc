{
    "name": "@vibe-rtc/demo",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview --host",
        "test": "vitest run --passWithNoTests",
        "test:watch": "vitest",
        "test:e2e": "playwright test --project=chromium",
        "test:e2e:headed": "playwright test --project=chromium --headed",
        "show-report:e2e": "playwright show-report",
        "clean": "rimraf dist",
        "precommit": "pnpm exec biome check src && pnpm run test"
    },
    "dependencies": {
        "@types/qrcode": "^1.5.6",
        "@vibe-rtc/rtc-core": "workspace:*",
        "@vibe-rtc/rtc-firebase": "workspace:*",
        "@vibe-rtc/rtc-react": "workspace:*",
        "qrcode": "^1.5.4",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-router-dom": "^7.9.5"
    },
    "devDependencies": {
        "@playwright/test": "^1.56.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/react": "^18.3.26",
        "@types/react-dom": "^18.3.7",
        "@vitejs/plugin-react": "^5.1.0",
        "jsdom": "^29.0.0",
        "rimraf": "^6.1.0",
        "typescript": "^5.9.3",
        "vite": "^7.1.12",
        "vitest": "^4.0.4"
    }
}
