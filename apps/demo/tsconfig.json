{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "target": "ES2020",
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "jsx": "react-jsx",
        "strict": true,
        "noEmit": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "allowJs": false,
        "types": ["vite/client"],
        "baseUrl": ".",
        "paths": {
            "@/*": ["src/*"],
            "@vibe-rtc/rtc-core": ["../../packages/rtc-core/src/index.ts"],
            "@vibe-rtc/rtc-firebase": ["../../packages/rtc-firebase/src/index.ts"],
            "@vibe-rtc/rtc-react": ["../../packages/rtc-react/src/index.ts"]
        }
    },
    "include": ["src", "vite.config.ts", "vitest.config.ts", "vitest.setup.ts", "env.d.ts"]
}
