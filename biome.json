{
    "$schema": "https://biomejs.dev/schemas/2.3.2/schema.json",
    "files": {
        "ignoreUnknown": true,
        "includes": [
            "apps/demo/src/**",
            "apps/demo/tests/**",
            "packages/rtc-core/src/**",
            "packages/rtc-core/tests/**",
            "packages/rtc-e2e/src/**",
            "packages/rtc-e2e/tests/**",
            "packages/rtc-react/src/**",
            "packages/rtc-react/tests/**",
            "packages/rtc-sdk/src/**",
            "packages/rtc-sdk/tests/**",
            "!**/*.map",
            "!**/dist",
            "!**/node_modules"
        ]
    },
    "formatter": {
        "includes": [
            "apps/demo/src/**",
            "apps/demo/tests/**",
            "packages/rtc-core/src/**",
            "packages/rtc-core/tests/**",
            "packages/rtc-e2e/src/**",
            "packages/rtc-e2e/tests/**",
            "packages/rtc-react/src/**",
            "packages/rtc-react/tests/**",
            "packages/rtc-sdk/src/**",
            "packages/rtc-sdk/tests/**",
            "!**/*.map",
            "!**/dist",
            "!**/node_modules"
        ],
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 100
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "complexity": {
                "noUselessCatch": "warn"
            }
        }
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single",
            "semicolons": "asNeeded",
            "arrowParentheses": "always",
            "bracketSameLine": false,
            "bracketSpacing": true,
            "jsxQuoteStyle": "double",
            "quoteProperties": "asNeeded",
            "trailingCommas": "all"
        }
    }
}
