{
    "name": "@vibe-rtc/rtc-react",
    "version": "0.4.0",
    "description": "React adapter (hook) for vibe-rtc core",
    "type": "module",
    "private": false,
    "keywords": [
        "web-rtc",
        "react"
    ],
    "homepage": "https://github.com/ahaodas/vibe-rtc/tree/master/packages/rtc-react",
    "repository": {
        "type": "git",
        "url": "https://github.com/ahaodas/vibe-rtc"
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs",
            "default": "./dist/index.mjs"
        }
    },
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "peerDependencies": {
        "react": ">=18"
    },
    "dependencies": {
        "@vibe-rtc/rtc-core": "workspace:^"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/react": "^18.3.28",
        "jsdom": "^29.0.1",
        "react": "18.3.1",
        "vitest": "^4.1.0"
    },
    "scripts": {
        "build": "tsup",
        "build:watch": "tsup --watch",
        "clean": "rm -rf dist",
        "test": "vitest run --passWithNoTests",
        "test:watch": "vitest"
    }
}
