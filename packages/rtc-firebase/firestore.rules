rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function authUidMatches(uid) {
      return request.auth == null ? false : request.auth.uid == uid;
    }

    function strLen(value, min, max) {
      return value is string
        && value.size() >= min
        && value.size() <= max;
    }

    function optionalStrLen(value, max) {
      return value == null || (value is string && value.size() <= max);
    }

    function optionalIntRange(value, min, max) {
      return value == null || (value is int && value >= min && value <= max);
    }

    function validIcePhase(value) {
      return value == null || value in ['LAN', 'STUN', 'STUN_ONLY', 'TURN_ENABLED'];
    }

    function validSignalPayload(value, expectedType) {
      return value is map
        && value.keys().hasOnly([
          'type',
          'sdp',
          'epoch',
          'sessionId',
          'forSessionId',
          'pcGeneration',
          'forPcGeneration',
          'gen',
          'forGen',
          'icePhase'
        ])
        && value.type == expectedType
        && strLen(value.sdp, 1, 20000)
        && (!('epoch' in value) || optionalIntRange(value.epoch, 0, 1000000))
        && (!('sessionId' in value) || optionalStrLen(value.sessionId, 128))
        && (!('forSessionId' in value) || optionalStrLen(value.forSessionId, 128))
        && (!('pcGeneration' in value) || optionalIntRange(value.pcGeneration, 0, 1000000))
        && (!('forPcGeneration' in value) || optionalIntRange(value.forPcGeneration, 0, 1000000))
        && (!('gen' in value) || optionalIntRange(value.gen, 0, 1000000))
        && (!('forGen' in value) || optionalIntRange(value.forGen, 0, 1000000))
        && (!('icePhase' in value) || validIcePhase(value.icePhase));
    }

    function validOffer(value) {
      return value == null || validSignalPayload(value, 'offer');
    }

    function validAnswer(value) {
      return value == null || validSignalPayload(value, 'answer');
    }

    function validRoomKeys(data) {
      return data is map
        && data.keys().hasOnly([
        'creatorUid',
        'callerUid',
        'calleeUid',
        'offer',
        'answer',
        'epoch',
        'createdAt',
        'updatedAt',
        'expiresAt'
      ]);
    }

    function validRoomCreate(data) {
      return signedIn()
        && validRoomKeys(data)
        && authUidMatches(data.creatorUid)
        && authUidMatches(data.callerUid)
        && data.calleeUid == null
        && data.offer == null
        && data.answer == null
        && data.epoch is int
        && data.epoch == 0
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && data.expiresAt is timestamp
        && data.expiresAt > request.time
        && data.expiresAt <= request.time + duration.value(4, 'h');
    }

    function roomChangedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function validRoomUpdateBase() {
      return signedIn()
        && resource != null
        && resource.data is map
        && roomChangedKeys().hasOnly(['callerUid', 'calleeUid', 'updatedAt'])
        && (
          !('updatedAt' in request.resource.data)
          || (
            request.resource.data.updatedAt is timestamp
            && resource.data.updatedAt is timestamp
            && request.resource.data.updatedAt >= resource.data.updatedAt
          )
        );
    }

    function canUpdateCallerUid() {
      return roomChangedKeys().hasOnly(['callerUid', 'updatedAt'])
        && ('callerUid' in request.resource.data)
        && authUidMatches(request.resource.data.callerUid);
    }

    function canUpdateCalleeUid() {
      return roomChangedKeys().hasOnly(['calleeUid', 'updatedAt'])
        && ('calleeUid' in request.resource.data)
        && authUidMatches(request.resource.data.calleeUid);
    }

    function validLeaseShape(data, role) {
      return data is map
        && data.keys().hasOnly([
          'role',
          'ownerUid',
          'ownerSessionId',
          'leaseVersion',
          'createdAt',
          'updatedAt'
        ])
        && data.role == role
        && strLen(data.ownerUid, 1, 128)
        && strLen(data.ownerSessionId, 8, 256)
        && data.leaseVersion is int
        && data.leaseVersion >= 1
        && (!('createdAt' in data) || data.createdAt is timestamp)
        && (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function validLeaseIncoming(data, role) {
      return validLeaseShape(data, role)
        && authUidMatches(data.ownerUid);
    }

    function validLeaseStored(data, role) {
      return validLeaseShape(data, role);
    }

    function validLeaseCreate(data, role) {
      return validLeaseIncoming(data, role)
        && 'createdAt' in data
        && 'updatedAt' in data;
    }

    function validParticipantKeys(data) {
      return data is map
        && data.keys().hasOnly([
        'uid',
        'role',
        'sessionId',
        'active',
        'offer',
        'answer',
        'createdAt',
        'updatedAt'
      ]);
    }

    function validParticipantCommon(data, role, uid) {
      return validParticipantKeys(data)
        && data.uid == uid
        && data.role == role
        && strLen(data.sessionId, 8, 256)
        && data.active is bool;
    }

    function validCallerParticipant(data, uid) {
      return validParticipantCommon(data, 'caller', uid)
        && (!('offer' in data) || validOffer(data.offer))
        && (!('answer' in data) || data.answer == null);
    }

    function validCallerParticipantCreate(data, uid) {
      return validCallerParticipant(data, uid)
        && 'createdAt' in data
        && 'updatedAt' in data;
    }

    function validCalleeParticipant(data, uid) {
      return validParticipantCommon(data, 'callee', uid)
        && (!('answer' in data) || validAnswer(data.answer))
        && (!('offer' in data) || data.offer == null);
    }

    function validCalleeParticipantCreate(data, uid) {
      return validCalleeParticipant(data, uid)
        && 'createdAt' in data
        && 'updatedAt' in data;
    }

    function validCandidateKeys(data) {
      return data.keys().hasOnly([
        'candidate',
        'sdpMid',
        'sdpMLineIndex',
        'usernameFragment',
        'sessionId',
        'epoch',
        'pcGeneration',
        'gen',
        'icePhase',
        'createdAt'
      ]);
    }

    function validCandidatePayload(data) {
      return validCandidateKeys(data)
        && data.candidate is string
        && (!('sdpMid' in data) || data.sdpMid == null || data.sdpMid is string)
        && (!('sdpMLineIndex' in data) || data.sdpMLineIndex == null || data.sdpMLineIndex is int)
        && (!('usernameFragment' in data) || data.usernameFragment == null || data.usernameFragment is string)
        && (!('sessionId' in data) || data.sessionId == null || data.sessionId is string)
        && (!('epoch' in data) || data.epoch == null || data.epoch is int)
        && (!('pcGeneration' in data) || data.pcGeneration == null || data.pcGeneration is int)
        && (!('gen' in data) || data.gen == null || data.gen is int)
        && (!('icePhase' in data) || validIcePhase(data.icePhase));
    }

    function validTakeoverEvent(data) {
      return data is map
        && data.keys().hasOnly([
          'type',
          'role',
          'targetUid',
          'targetSessionId',
          'byUid',
          'bySessionId',
          'createdAt'
        ])
        && data.type == 'role_taken_over'
        && data.role in ['caller', 'callee']
        && strLen(data.targetUid, 1, 128)
        && strLen(data.targetSessionId, 8, 256)
        && authUidMatches(data.byUid)
        && strLen(data.bySessionId, 8, 256)
        && data.createdAt is timestamp;
    }

    function roomExists(roomId) {
      return exists(/databases/$(database)/documents/rooms/$(roomId));
    }

    function roomData(roomId) {
      return get(/databases/$(database)/documents/rooms/$(roomId)).data;
    }

    function roomCreatorUid(roomId) {
      return roomExists(roomId) ? roomData(roomId).creatorUid : null;
    }

    function leaseExists(roomId, role) {
      return exists(/databases/$(database)/documents/rooms/$(roomId)/leases/$(role));
    }

    function leaseData(roomId, role) {
      return get(/databases/$(database)/documents/rooms/$(roomId)/leases/$(role)).data;
    }

    function leaseDataOrNull(roomId, role) {
      return leaseExists(roomId, role) ? leaseData(roomId, role) : null;
    }

    function leaseCreatedAt(roomId, role) {
      return leaseExists(roomId, role) ? leaseData(roomId, role).createdAt : null;
    }

    function leaseVersion(roomId, role) {
      return leaseExists(roomId, role) && leaseData(roomId, role).leaseVersion is int
        ? leaseData(roomId, role).leaseVersion
        : 0;
    }

    function leaseOwnerUid(roomId, role) {
      return leaseExists(roomId, role) ? leaseData(roomId, role).ownerUid : null;
    }

    match /rooms/{roomId} {
      allow list: if false;
      allow get: if signedIn();
      allow create: if validRoomCreate(request.resource.data);
      allow update: if validRoomUpdateBase() && (canUpdateCallerUid() || canUpdateCalleeUid());
      allow delete: if signedIn()
        && authUidMatches(roomCreatorUid(roomId));

      match /leases/{role} {
        allow list: if false;
        allow get: if signedIn();
        allow create: if signedIn() && validLeaseCreate(request.resource.data, role);
        allow update: if signedIn()
          && validLeaseIncoming(request.resource.data, role)
          && validLeaseStored(leaseDataOrNull(roomId, role), role)
          && (!('createdAt' in request.resource.data) || request.resource.data.createdAt == leaseCreatedAt(roomId, role))
          && ('leaseVersion' in request.resource.data)
          && request.resource.data.leaseVersion == leaseVersion(roomId, role) + 1;
        allow delete: if signedIn()
          && authUidMatches(leaseOwnerUid(roomId, role));
      }

      match /events/{eventId} {
        allow read: if signedIn();
        allow create: if signedIn() && validTakeoverEvent(request.resource.data);
        allow update, delete: if false;
      }

      match /callers/{uid} {
        allow read: if signedIn();
        allow create: if signedIn()
          && authUidMatches(uid)
          && validCallerParticipant(request.resource.data, uid);
        allow update: if signedIn()
          && resource != null
          && authUidMatches(uid)
          && validCallerParticipant(request.resource.data, uid)
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.role == resource.data.role
          && (!('createdAt' in request.resource.data) || request.resource.data.createdAt == resource.data.createdAt);
        allow delete: if authUidMatches(uid);

        match /candidates/{candidateId} {
          allow read: if signedIn();
          allow create, update, delete: if request.auth != null && request.auth.uid == uid;
        }
      }

      match /callees/{uid} {
        allow read: if signedIn();
        allow create: if signedIn()
          && authUidMatches(uid)
          && validCalleeParticipant(request.resource.data, uid);
        allow update: if signedIn()
          && resource != null
          && authUidMatches(uid)
          && validCalleeParticipant(request.resource.data, uid)
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.role == resource.data.role
          && (!('createdAt' in request.resource.data) || request.resource.data.createdAt == resource.data.createdAt);
        allow delete: if authUidMatches(uid);

        match /candidates/{candidateId} {
          allow read: if signedIn();
          allow create, update, delete: if request.auth != null && request.auth.uid == uid;
        }
      }
    }
  }
}
