{
    "name": "@vibe-rtc/rtc-firebase",
    "version": "0.2.8",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./node": {
            "types": "./dist/node.d.ts",
            "import": "./dist/node.js",
            "require": "./dist/node.cjs"
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "homepage": "https://github.com/ahaodas/vibe-rtc/tree/master/packages/rtc-firebase",
    "repository": {
        "type": "git",
        "url": "https://github.com/ahaodas/vibe-rtc"
    },
    "sideEffects": false,
    "scripts": {
        "build": "tsup src/index.ts src/node.ts --dts --format esm,cjs --clean",
        "test": "vitest -c vitest.config.ts --run tests/unit tests/integration",
        "test:rules": "vitest -c vitest.config.ts --run tests/rules",
        "test:unit": "vitest -c vitest.config.ts --run tests/unit",
        "emulator": "npx firebase-tools emulators:start --project demo --only firestore,auth --import=.fb-data --export-on-exit",
        "rules:deploy": "npx firebase-tools deploy --only firestore:rules --project ${FIREBASE_PROJECT_ID:-demo}",
        "rules:deploy:ci": "npx firebase-tools deploy --only firestore:rules --project ${FIREBASE_PROJECT_ID:-demo} --non-interactive"
    },
    "dependencies": {
        "@vibe-rtc/rtc-core": "workspace:^",
        "firebase": "^12.11.0"
    },
    "devDependencies": {
        "@firebase/rules-unit-testing": "^5.0.0",
        "dotenv": "^17.3.1",
        "firebase-tools": "^15.11.0",
        "vitest": "^4.1.0"
    }
}
